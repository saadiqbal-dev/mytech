    <script
      type="text/javascript"
      src="/themes/stormimc/js/app.min.js?id=cc8bd44b39499969cbfb"
    ></script>

    <script type="text/javascript">
      $(document).ready(function () {
        var resultURL = "";
        var params = {};
        var hasValidURL = false;
        var hasCampaignSource = false;

        var formatUrl = function () {
          $.each(params, function (key, val) {
            if (key == "campaign_url") {
              var validURL =
                /(ftp|http|https):\/\/(\w+:{0,1}\w*@)?(\S+)(:[0-9]+)?(\/|\/([\w#!:.?+=&%@!\-\/]))?/.test(
                  val
                );
              if (validURL) {
                hasValidURL = true;
              } else {
                hasValidURL = false;
              }

              console.log(hasValidURL);
            }

            if (key == "utm_source" && val != "") {
              hasCampaignSource = true;
            }

            if (hasValidURL && hasCampaignSource) {
              resultURL = params["campaign_url"];

              if (resultURL.split("/").length <= 3) {
                if (resultURL.substr(resultURL.length - 1) != "/") {
                  resultURL += "/";
                }
              }

              if (resultURL.indexOf("?") == -1) {
                resultURL += "?";
              }

              if (params["utm_source"].length > 0) {
                resultURL +=
                  "utm_source=" + params["utm_source"].replace(/ /g, "+");
              }

              if (
                params["utm_medium"] != undefined &&
                params["utm_medium"].length > 0
              ) {
                resultURL +=
                  "&utm_medium=" + params["utm_medium"].replace(/ /g, "+");
              }

              if (
                params["utm_campaign"] != undefined &&
                params["utm_campaign"].length > 0
              ) {
                resultURL +=
                  "&utm_campaign=" + params["utm_campaign"].replace(/ /g, "+");
              }

              if (
                params["utm_term"] != undefined &&
                params["utm_term"].length > 0
              ) {
                resultURL +=
                  "&utm_term=" + params["utm_term"].replace(/ /g, "+");
              }

              if (
                params["utm_id"] != undefined &&
                params["utm_id"].length > 0
              ) {
                resultURL += "&utm_id=" + params["utm_id"].replace(/ /g, "+");
              }

              if (
                params["utm_content"] != undefined &&
                params["utm_content"].length > 0
              ) {
                resultURL +=
                  "&utm_content=" + params["utm_content"].replace(/ /g, "+");
              }

              // Encode special chars
              resultURL = encodeURI(resultURL);
              console.log(resultURL);
              $("#campaign-result-url").val(resultURL);
              $(".campaign-copy").show();
              $(".campaign-copy-status").text("");
            } else if (!hasValidURL) {
              $(".campaign-copy-status").text(
                "Invalid URL, please provide url with protocol. e.g  https://www.example.com/landing-page-1"
              );
              $("#campaign-result-url").val("");
              $(".campaign-copy").hide();
            }
          });
        };

        $("#campaign-builder input, #campaign-builder textarea").each(function (
          index
        ) {
          $(this).keyup(function () {
            var key = $(this).attr("id");
            var val = $(this).val();

            params[key] = val;

            formatUrl();
          });

          var key = $(this).attr("id");
          var val = $(this).val();
          params[key] = val;

          formatUrl();
        });

        $("#campaign-builder").submit(function () {
          copyText();
          return false;
        });

        $("#campaign-result-url").on("click", function () {
          copyText();
          return false;
        });

        function copyText() {
          var text = $("#campaign-result-url").val();
          navigator.clipboard.writeText(text).then(
            function () {
              $(".campaign-copy-status")
                .addClass("text-success")
                .removeClass("text-danger")
                .text("Copied to clipboard!");

              setTimeout(function () {
                $(".campaign-copy-status")
                  .addClass("text-danger")
                  .removeClass("text-success")
                  .text("");
              }, 2000);
            },
            function (err) {
              $(".campaign-copy-status").text(
                "Cannot copy to clipboard! Please try again."
              );

              setTimeout(function () {
                $(".campaign-copy-status").text("");
              }, 2000);
            }
          );
        }

        function isValidHttpUrl(string) {
          try {
            const newUrl = new URL(string);
            return newUrl.protocol === "http:" || newUrl.protocol === "https:";
          } catch (err) {
            return false;
          }
        }
      });
    </script>
  </body>
</html>
