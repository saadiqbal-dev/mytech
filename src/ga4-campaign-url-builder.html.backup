    <main class="service-category">
      <section animateItem class="services-section services-1 template-header">
        <div class="container vertical-align position-relative">
          <h1>Google Analytics 4&nbsp;</h1>

          <h1>UTM&nbsp;Link Builder</h1>
        </div>
      </section>

      <section class="service-section service-2 bg-none">
        <div class="container container-full mobile-ordered">
          <div class="row align-items-center">
            <div class="col-sm-6 order-1 order-lg-1 pb-4 pb-sm-0">
              <h2>
                This tool allows you to easily add campaign parameters to URLs
                so you can measure Custom Campaigns in Google Analytics.
              </h2>

              <p>
                Fill out the required fields (marked with *) in the form below,
                and once complete the full campaign URL will be generated for
                you.
              </p>
              <p>
                <small
                  >Note: the generated URL is automatically updated as you make
                  changes.</small
                >
              </p>
            </div>

            <div class="col-sm-6 order-2 order-lg-2">
              <p class="text-center">
                <img
                  class="w-auto"
                  alt="Laptop Showing Google Analytics Tracking Data"
                  src="/themes/stormimc/img/webp/device.webp"
                />
              </p>
            </div>
          </div>
        </div>
      </section>
      <section class="service-section service-2 bg-none pt-4 pt-md-5">
        <div class="container container-full mobile-ordered">
          <div class="row">
            <div class="col-lg-5 col-xl-6 order-1 order-lg-1 pr-lg-3 pr-xl-5">
              <form id="campaign-builder" class="mb-5 mb-lg-0 pb-3 pb-lg-0">
                <div class="form-group">
                  <input
                    id="campaign_url"
                    type="text"
                    class="form-control fs-16"
                    placeholder="Landing Page URL *"
                  />
                  <small class="form-text text-muted"
                    >The full website URL (e.g.
                    https://www.example.com/landing-page-1)</small
                  >
                </div>

                <div class="form-group">
                  <input
                    id="utm_medium"
                    type="text"
                    placeholder="Campaign Medium *"
                    class="form-control fs-16"
                  />
                  <small class="form-text text-muted"
                    >Marketing Medium (e.g banner, email, social, affiliate, cpc
                    etc)</small
                  >
                </div>

                <div class="form-group">
                  <input
                    id="utm_source"
                    type="text"
                    placeholder="Campaign Source *"
                    class="form-control fs-16"
                  />
                  <small class="form-text text-muted"
                    >The referring source (e.g. facebook, linkedin, instagram,
                    newsletter, google etc )</small
                  >
                </div>

                <div class="form-group">
                  <input
                    id="utm_campaign"
                    type="text"
                    placeholder="Campaign Name (Optional)"
                    class="form-control fs-16"
                  />
                  <small class="form-text text-muted"
                    >Product, promo code, or slogan (e.g. spring_sale)</small
                  >
                </div>

                <div class="form-group">
                  <input
                    id="utm_content"
                    type="text"
                    placeholder="Campaign Content (Optional)"
                    class="form-control fs-16"
                  />
                  <small class="form-text text-muted"
                    >Use to differentiate ads</small
                  >
                </div>

                <div class="form-group">
                  <input
                    id="utm_term"
                    placeholder="Campaign Term (Optional)"
                    type="text"
                    class="form-control fs-16"
                  />
                  <small class="form-text text-muted"
                    >Identify the paid keywords</small
                  >
                </div>

                <div class="form-group">
                  <input
                    id="utm_id"
                    placeholder="Campaign ID (Optional)"
                    type="text"
                    class="form-control fs-16"
                  />
                  <small class="form-text text-muted"
                    >The ads campaign id</small
                  >
                </div>
                <div class="text-left">
                  <h3>Share the generated campaign URL</h3>
                  <p>
                    Use this URL in any promotional channels you want to be
                    associated with this custom campaign.
                  </p>
                </div>
                <div class="form-group campaign-results position-relative">
                  <label for="campaign-result-url" class="textarea-label"
                    >Generated URL</label
                  >
                  <textarea
                    id="campaign-result-url"
                    rows="3"
                    readonly="readonly"
                    class="form-control fs-16"
                  ></textarea>
                </div>

                <div class="form-group">
                  <button class="btn btn-red campaign-copy">
                    <span
                      ><img
                        src="/themes/stormimc/img/webp/copy-white.webp"
                        width="15"
                        height=""
                        alt=""
                      />
                      <i>COPY URL</i></span
                    >
                  </button>
                  <small
                    class="form-text text-danger campaign-copy-status"
                  ></small>
                </div>
              </form>
            </div>

            <div class="col-lg-7 col-xl-6 order-2 order-lg-2 overflow-visible">
              <div class="position-relative grey-column">
                <div class="column-label"><span>Need some help?</span></div>
                <div class="fs-18 text-left">
                  <p>
                    <strong
                      >More information and examples for each parameter</strong
                    ><br />
                    The following table gives a detailed explanation and example
                    of each of the campaign parameters:
                  </p>
                </div>
                <table
                  id="resp-table"
                  class="table table-borderless responsive-table fs-14"
                >
                  <tr>
                    <td><strong>Parameter</strong></td>
                    <td class="text-lg-center"><strong>Required</strong></td>
                    <td class="text-lg-center"><strong>Example</strong></td>
                    <td><strong>Description</strong></td>
                  </tr>
                  <tr>
                    <td data-title="Parameter">
                      <strong>Campaign Medium</strong><br /><span class="label"
                        >utm_medium</span
                      >
                    </td>
                    <td data-title="Required" class="text-lg-center">
                      <strong>Yes</strong>
                    </td>
                    <td data-title="Example" class="text-lg-center full-label">
                      <span class="label">social</span>
                    </td>
                    <td data-title="Description">
                      Use <span class="label">utm_medium</span> to identify a
                      medium such as email or cost-per-click.
                    </td>
                  </tr>
                  <tr>
                    <td data-title="Parameter">
                      <strong>Campaign Source</strong><br /><span class="label"
                        >utm_source</span
                      >
                    </td>
                    <td data-title="Required" class="text-lg-center">
                      <strong>Yes</strong>
                    </td>
                    <td data-title="Example" class="text-lg-center full-label">
                      <span class="label">facebook</span>
                    </td>
                    <td data-title="Description">
                      Use <span class="label">utm_source</span> to identify a
                      search engine, newsletter name, or other source.
                    </td>
                  </tr>
                  <tr>
                    <td data-title="Parameter">
                      <strong>Campaign Name</strong><br /><span class="label"
                        >utm_campaign</span
                      >
                    </td>
                    <td data-title="Required" class="text-lg-center">
                      <strong>No</strong>
                    </td>
                    <td data-title="Example" class="text-lg-center full-label">
                      <span class="label">flash_sale</span>
                    </td>
                    <td data-title="Description">
                      Used for keyword analysis. Use
                      <span class="label">utm_campaign</span> to identify a
                      specific product promotion or strategic campaign.
                    </td>
                  </tr>
                  <tr>
                    <td data-title="Parameter">
                      <strong>Campaign Term</strong><br /><span class="label"
                        >utm_term</span
                      >
                    </td>
                    <td data-title="Required" class="text-lg-center">
                      <strong>No</strong>
                    </td>
                    <td data-title="Example" class="text-lg-center full-label">
                      <span class="label">acme+widget</span>
                    </td>
                    <td data-title="Description">
                      Used for paid search. Use<span>utm_term</span> to note the
                      keywords for this ad.
                    </td>
                  </tr>
                  <tr>
                    <td data-title="Parameter">
                      <strong>Campaign Content</strong><br /><span class="label"
                        >utm_content</span
                      >
                    </td>
                    <td data-title="Required" class="text-lg-center">
                      <strong>No</strong>
                    </td>
                    <td data-title="Example" class="text-lg-center full-label">
                      <span class="label">logolink</span>
                    </td>
                    <td data-title="Description">
                      Used for A/B testing and content-targeted ads. Use
                      <span class="label">utm_content</span> to differentiate
                      ads or links that point to the same URL.
                    </td>
                  </tr>
                  <tr>
                    <td data-title="Parameter">
                      <strong>Campaign ID</strong><br /><span class="label"
                        >utm_id</span
                      >
                    </td>
                    <td data-title="Required" class="text-lg-center">
                      <strong>No</strong>
                    </td>
                    <td data-title="Example" class="text-lg-center full-label">
                      <span class="label">xyc.321</span>
                    </td>
                    <td data-title="Description">
                      Used to identify which ads campaign this referral
                      references. Use <span class="label">utm_id</span> to
                      identify a specific ads campaign.
                    </td>
                  </tr>
                </table>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section
        class="service-section service-2 bg-none mb-5 mt-5 mt-sm-0 overflow-visible"
